{
    "name": "bju/mova",
    "description": "MOVA Fleet & Driver Management Platform",
    "type": "project",
    "config": {
        "process-timeout": 0
    },
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-gd": "*",
        "phpoffice/phpspreadsheet": "^5.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "dev": "php -S 127.0.0.1:8000 -t public public/router.php",
        "migrate": "php migrations/run.php",
        "seed": "php migrations/seed.php"
    }
}
